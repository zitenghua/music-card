{
  "name": "music-card-maker",
  "version": "1.0.1",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "icon": "node scripts/generate-icon.js",
    "dist": "npm run icon && electron-builder",
    "dist:win": "npm run icon && electron-builder --win"
  },
  "build": {
    "appId": "com.music-card-maker",
    "productName": "音乐卡片制作工具",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "yue2.html",
      "yue2.css",
      "yue2.js",
      "covers/**/*"
    ],
    "extraResources": [
      {
        "from": "covers",
        "to": "covers",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": ["nsis"]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.2",
    "sharp": "^0.35.3"
  }
}
