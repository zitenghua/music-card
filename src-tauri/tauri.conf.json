{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "音乐卡片制作工具",
  "version": "1.0.0",
  "identifier": "com.music-card-maker.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "音乐卡片制作工具",
        "width": 1100,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../covers/*",
      "../configs/*",
      "../output/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
